# ==========================================
# Hospital Database Project - .gitignore
# ==========================================

# === Operating System Files ===
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# === IDEs and Editors ===
# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# JetBrains (IntelliJ, PyCharm, WebStorm, DataGrip)
.idea/
*.iws
*.iml
*.ipr

# === PostgreSQL & Database Tools ===
# Ignore database backups, dumps, and pgAdmin logs/credentials

# uncomment the following line if you want to ignore .backup files
#*.backup
*.dump
*.sql.gz
*.sql.zip
.pgpass
pgadmin4.db
pgadmin4.log
*.db
*.sqlite
*.sqlite-journal

# === Python & GUI (Tkinter) ===
# Ignore compiled Python files and virtual environments
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
build/
dist/
*.egg-info/
.ipynb_checkpoints/

# === Environment Variables & Secrets ===
# CRITICAL: Never commit secrets or credentials to Git!
.env
.env.local
*.pem
*.key
auth.json

# === Temporary Files & Logs ===
*.log
*.bak
*.tmp
*.temp

# === Reports & Documentation ===
# Ignore MS Office temporary files, but keep the actual reports (.docx, .pdf)
~$*.doc*
~$*.ppt*
~$*.xls*

# === Data Exports (Stage 4) ===
# Uncomment the following line to ignore large CSV files if they exceed GitHub limits.
# By default, this is commented out in case the instructor requires CSV submission.
# *.csv